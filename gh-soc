    exit 1
  fi

  local var_name="$1"
  shift # Remove the first argument to treat the rest as an array
  local -a arr=("$@")

  if [[ "${#arr[@]}" -eq 0 ]]; then
    echo "${ERR} '${var_name}' is an empty array." >&2
    return 1
  elif [[ "${VERBOSE}" -eq 1 ]]; then
    echo
    echo "${YUP} '${var_name}' is a non-empty array: ${arr[@]}."
