main() {
  # Check if an argument (init, precheck, open, log, close, reopen or precheck)
  # was provided
  if [[ "$#" -eq 0 ]]; then
    echo -n "${WRN} Usage: gh soc [init|precheck|sync|open|assign|log|close|"
    echo "reopen|delete]"
    exit 1
  fi

  # TODO:
  # Add precheck to every function
  # END:
  
  # Run the appropriate function based on the argument
  case "$1" in
    init)
      init
      ;;
    precheck)
      precheck
      ;;
    sync)
      # Validate global variables before running the sync function
      precheck
      sync
      ;;
    open)
      open
      ;;
    assign)
      # Check if the correct number of non-empty arguments is passed
      if [[ "$#" -ne 2 || -z "$2" ]]; then
	echo "${ERR} Invalid number of arguments or empty argument." >&2
	echo "${WRN} Usage: gh soc assign <repository name>"
	exit 1
      fi
      assign "$2"
      ;;
    log)
      log
      ;;
    close)
      close
      ;;
    reopen)
      reopen
      ;;
    delete)
      delete
      ;;
    *)
      echo -n "${ERR} Invalid argument. Available options: " >&2
      echo "init, precheck, sync, open, assign, log, close, reopen, delete" >&2
      exit 1
      ;;
  esac
}
main "$@"
