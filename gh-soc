#!/usr/bin/env bash

# Aborts the script when the first error is detected.
set -o errexit
# Aborts the script when the first undefined variable is detected.
set -o nounset
# Allow for ERR trap inheritance through shell functions.
set -o errtrace

trap 'error_handler ${BASH_SOURCE} ${LINENO}' ERR

# Unicode characters for visual representation in the terminal
# White Heavy Check Mark (Unicode: U+2705)
OK=✅
# Check Mark (Unicode: U+2713)
YUP=✓
# High Voltage Sign as warning mark (Unicode: U+26A1)
WRN=⚡
# Cross Mark (Unicode: U+274C)
ERR=❌

error_handler() {
  local src="$1"
  local line="$2"

  echo "${ERR} Error: in ${src} at line ${line}" >&2
}

remove_tmp_file() {
  local file_to_remove="$1"

  if [[ -f "$file_to_remove" ]]; then
    rm -f "${file_to_remove}"
    echo "${YUP} Temporary file '${file_to_remove}' has been deleted"
   fi
}

check_if_gh_has_required_token_scopes() {
  # Aborts the script when the first error is detected.
  set -o errexit

  local -a token_scopes
  local -a missing_scopes

  # Fetch the current token scopes using 'gh', extract line with 'grep' and use
  # 'sed' to parse the line
  token_scopes=$(gh auth status | grep 'Token scopes' | sed 's/.*Token scopes: //')

  # Check for each required scope
  for scope in "${GH_CLI_TOKEN_SCOPES[@]}"; do
    if [[ "${token_scopes}" != *"${scope}"* ]]; then
      missing_scopes+=("${scope}")
    fi
  done

  # Inform the user about the status
  if [[ "${#missing_scopes[@]}" -ne 0 ]]; then
    echo "${ERR} Missing required token scopes:" >&2
    for scope in "${missing_scopes[@]}"; do
      echo "- ${scope}" >&2
    done
    exit 1
  fi
}

check_if_source_repos_exist() {
  # Aborts the script when the first error is detected.
  set -o errexit
  # Initialize a flag to track if any repository does not exist
  local repo_noexists_flag=0

  for ((i=0; i<"${#SOURCE_REPOS[@]}"; i++)); do
    # Check if the repository exists
    if gh repo view "${SOURCE_REPOS_OWNER}/${SOURCE_REPOS[i]}" &> /dev/null; then
      echo -n "${YUP} Repository ${SOURCE_REPOS_OWNER}/${SOURCE_REPOS[i]} "
      echo "exists as expected."
    else
      echo -n "${ERR} Repository ${SOURCE_REPOS_OWNER}/${SOURCE_REPOS[i]} " >&2
      echo "no exists." >&2
      repo_noexists_flag=1
    fi
  done

  # Check the flag and exit with an error if any repository does not exist
  if [[ "${repo_noexists_flag}" -eq 1 ]]; then
    echo -n "${ERR} For proper functioning, it is required that " >&2
    echo -n "the repositories listed in the 'SOURCE_REPOS' array " >&2
    echo -n "in the 'source_config.sh' file exist " >&2
    echo "on the '${SOURCE_REPOS_OWNER}' account." >&2
    exit 1
  else
    echo "${OK} Checking – if the source repositories exist – has been completed."
  fi
}

check_if_target_repos_noexist() {
  # Aborts the script when the first error is detected.
  set -o errexit
  # Initialize a flag to track if any repository already exists
  local repo_exists_flag=0

  for ((i=0; i<"${#TARGET_REPOS[@]}"; i++)); do
    # Check if the repository exists
    if ! gh repo view "${GH_ORG_NAME}/${TARGET_REPOS[i]}" &> /dev/null; then
      echo -n "${YUP} Repository ${GH_ORG_NAME}/${TARGET_REPOS[i]} "
      echo "not yet exists as expected."
    else
      echo -n "${ERR} Repository ${GH_ORG_NAME}/${TARGET_REPOS[i]} " >&2
      echo "already exists." >&2
      repo_exists_flag=1
    fi
  done

  # Check the flag and exit with an error if any repository already exists
  if [[ "${repo_exists_flag}" -eq 1 ]]; then
    echo -n "${ERR} For proper functioning, it is required that " >&2
    echo -n "the repositories listed in the 'TARGET_REPOS' array " >&2
    echo -n "in the 'user_config.sh' file do not exist " >&2
    echo "on the '${GH_ORG_NAME}' account." >&2
    exit 1
  else
    echo -n "${OK} Checking – if the target repositories not yet exist – "
    echo "has been completed."
  fi
}

fork_repositories() {
  # Disable the script's abort-on-first-error feature.
  set +o errexit

  for ((i=0; i<"${#SOURCE_REPOS[@]}"; i++)); do

    # Fork the repository to the organization without cloning it locally.
    gh repo fork "${SOURCE_REPOS_OWNER}"/"${SOURCE_REPOS[i]}" \
       --org "${GH_ORG_NAME}" \
       --fork-name "${TARGET_REPOS[i]}" \
       --clone=false

    if [[ $? -ne 0 ]]; then
      echo -n "${ERR} An error occurred while forking the " >&2
      echo -n "${SOURCE_REPOS_OWNER}/${SOURCE_REPOS[i]} repository to " >&2
      echo "${GH_ORG_NAME}/${TARGET_REPOS[i]}" >&2
      exit 1
    fi
  done
  echo "${OK} Forking repositories has been completed"
}

